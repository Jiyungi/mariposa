# ============================================================================
# Mariposa — Environment Variables (example)
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values.
#   cp .env_example .env.local
# `.env.local` is gitignored and must NEVER be committed.
# Anything prefixed with NEXT_PUBLIC_ is exposed to the browser — keep secrets
# WITHOUT that prefix.
# ============================================================================


# ----------------------------------------------------------------------------
# Integrations
# ----------------------------------------------------------------------------

# Anthropic Claude — primary reasoning, structured extraction, grounded chat
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Deepgram — primary voice/transcript layer for insurance and clinic flows
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
USE_DEEPGRAM_VOICE=true

# Orkes Agentspan — durable orchestration; local fallback when disabled/unhealthy
USE_AGENTSPAN=false
# Legacy alias for USE_AGENTSPAN
USE_ORKES=false
AGENTSPAN_SERVER_URL=http://localhost:6767
AGENTSPAN_API_KEY=
# Legacy aliases
ORKES_API_KEY=
ORKES_BASE_URL=http://localhost:6767
AGENTSPAN_MODEL=openai/gpt-4o-mini
ORKES_WORKFLOW_NAME=mariposa-insurance-flow

# Arize — AI tracing/evals; no-op when disabled or unset
ENABLE_ARIZE=false
ARIZE_API_KEY=
ARIZE_SPACE_ID=
ARIZE_PROJECT_NAME=mariposa

# Sentry — error monitoring; no-op when unset
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Browserbase — synthetic member-portal verification (Fetch API)
# Set USE_BROWSERBASE=true and a public NEXT_PUBLIC_APP_URL for live fetch.
USE_BROWSERBASE=false
BROWSERBASE_API_KEY=


# ----------------------------------------------------------------------------
# xAI / Grok — optional voice and chat path (off when USE_MOCK_AI=true)
# ----------------------------------------------------------------------------
# Primary key name used by the app. GROK_API_KEY is supported as a fallback.
XAI_API_KEY=
GROK_API_KEY=

# REST base URL for Grok chat/completions
XAI_API_BASE_URL=https://api.x.ai/v1

# Text model used for reasoning, summary, and grounded chat
XAI_MODEL=grok-4

# Grok Voice Agent — real-time WebSocket endpoint for live calls (xAI sponsor)
# Default on when XAI_API_KEY is set and USE_MOCK_AI=false.
XAI_VOICE_WS_URL=wss://api.x.ai/v1/realtime
XAI_VOICE_MODEL=grok-voice-latest
USE_GROK_VOICE=true

# Toggle: when true, skip live Grok/voice calls and use the deterministic
# mock fallbacks (use this for rehearsals so you don't burn credits / risk
# a live failure). Set to false for the real demo.
USE_MOCK_AI=false

# Reactive-graph timing (Inngest). Both accept Inngest duration strings.
# CHECKIN_DELAY: how long the workflow sleeps before the male-track re-test
#   Check_In fires. Represents the ~72-day (~10-12 week) sperm-regeneration
#   horizon; set to seconds (e.g. "10s") on stage so the Check_In is demoable.
CHECKIN_DELAY=10s
# APPROVAL_WAIT_TIMEOUT: how long the workflow pauses at the booking
#   Approval_Gate (waitForEvent couple.booking.approved) before expiring and
#   leaving the appointment pending with a "needs approval" state.
APPROVAL_WAIT_TIMEOUT=5m


# ----------------------------------------------------------------------------
# Supabase  — Postgres database (free tier)
# Project Settings -> API in the Supabase dashboard
# ----------------------------------------------------------------------------
# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# SERVER ONLY — bypasses row-level security. Never expose to the browser,
# never commit. Used for seeding and Inngest workflow writes.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# Optional: direct Postgres connection string (for migrations / seeding scripts)
DATABASE_URL=postgresql://postgres:[password]@db.your-project-ref.supabase.co:5432/postgres


# ----------------------------------------------------------------------------
# Inngest  (SPONSOR) — autonomous workflow orchestration
# LOCAL dev: leave both keys blank, keep INNGEST_DEV=true. The Inngest Dev
#   Server (npx inngest-cli dev) runs everything with no keys.
# VERCEL deploy (REQUIRED for submission): both keys ARE needed, and set
#   INNGEST_DEV=false. Get them at inngest.com -> select your "Production"
#   environment -> the key icon next to the environment switcher.
# ----------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# true for local Dev Server, false on the Vercel deployment
INNGEST_DEV=true


# ----------------------------------------------------------------------------
# App config
# ----------------------------------------------------------------------------
# Base URL of the app (used for callbacks / absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment (development | production)
NODE_ENV=development


# ----------------------------------------------------------------------------
# RAG (Supabase pgvector + Grok) — grounded chat retrieval
# ----------------------------------------------------------------------------
# Optional embedding model for seed:knowledge (falls back to local vectors)
# XAI_EMBEDDING_MODEL=text-embedding-3-small

# ----------------------------------------------------------------------------
# Redis — sponsor-aligned RAG, memory, and optional semantic cache
# Seed once: npm run seed:redis
# Verify connection/index: npm run verify:redis
# ----------------------------------------------------------------------------
# Use redis:// or rediss:// depending on your Redis Cloud "Connect" string.
# If verify hangs or TLS errors, try switching schemes.
REDIS_URL=redis://default:password@your-redis-host:6379
REDIS_VECTOR_INDEX=mariposa-rag
REDIS_SEMANTIC_CACHE=true
REDIS_AGENT_MEMORY=true

# ----------------------------------------------------------------------------
# AgentPhone — optional outbound voice (non-Grok model; off by default)
# Only used when USE_GROK_VOICE=false AND USE_AGENTPHONE=true.
# Synthetic demo numbers only.
# ----------------------------------------------------------------------------
USE_AGENTPHONE=false
AGENTPHONE_API_KEY=
AGENTPHONE_AGENT_ID=
AGENTPHONE_FROM_NUMBER_ID=
AGENTPHONE_TO_NUMBER=
# AGENTPHONE_BASE_URL=https://api.agentphone.ai/v1
